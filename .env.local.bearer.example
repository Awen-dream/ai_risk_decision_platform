# Core runtime mode
AI_RISK_KNOWLEDGE_BACKEND=file
AI_RISK_TOOL_BACKEND=http

# Agent API
AI_RISK_API_HOST=127.0.0.1
AI_RISK_API_PORT=8000

# Knowledge source
AI_RISK_KNOWLEDGE_DIR=data/knowledge

# External HTTP risk service
AI_RISK_TOOL_HTTP_BASE_URL=https://risk-api.example.com
AI_RISK_TOOL_HTTP_TIMEOUT_SEC=5

# HTTP endpoint mapping
AI_RISK_TOOL_HTTP_METRIC_PATH=/v2/metrics
AI_RISK_TOOL_HTTP_CASE_PATH=/v2/cases/search
AI_RISK_TOOL_HTTP_ORDER_PATH_TEMPLATE=/v2/orders/{order_id}/profile
AI_RISK_TOOL_HTTP_STRATEGY_PROFILE_PATH_TEMPLATE=/v2/strategies/{strategy_id}
AI_RISK_TOOL_HTTP_STRATEGY_SIMULATION_PATH_TEMPLATE=/v2/strategies/{strategy_id}/simulation
AI_RISK_TOOL_HTTP_GRAPH_RELATION_PATH_TEMPLATE=/v2/graph/{entity_id}
AI_RISK_TOOL_HTTP_COUNTRY_PARAM=market
AI_RISK_TOOL_HTTP_CHANNEL_PARAM=payment_channel

# Bearer authentication
AI_RISK_TOOL_HTTP_AUTH_MODE=bearer
AI_RISK_TOOL_HTTP_AUTH_HEADER=Authorization
AI_RISK_TOOL_HTTP_AUTH_TOKEN=replace-with-real-bearer-token
