# Core runtime mode
AI_RISK_KNOWLEDGE_BACKEND=file
AI_RISK_TOOL_BACKEND=http

# Agent API
AI_RISK_API_HOST=127.0.0.1
AI_RISK_API_PORT=8000

# Mock risk service
AI_RISK_RISK_SERVICE_HOST=127.0.0.1
AI_RISK_RISK_SERVICE_PORT=8090
# Local recovery drills only. Never enable on a shared or real risk service.
AI_RISK_RISK_SERVICE_FAULT_INJECTION_ENABLED=false

# Knowledge source
AI_RISK_KNOWLEDGE_DIR=data/knowledge

# Runtime persistence
# Supported store backends: memory / file / sqlite
AI_RISK_SESSION_STORE_BACKEND=sqlite
AI_RISK_CASE_STORE_BACKEND=sqlite
AI_RISK_DATABASE_PATH=.data/platform.db
AI_RISK_SESSION_STORE_PATH=.data/sessions.json
AI_RISK_CASE_STORE_PATH=.data/cases.json

# File-based local data
AI_RISK_METRIC_SNAPSHOT_PATH=data/risk/metric_snapshots.json
AI_RISK_CASE_RECORD_PATH=data/risk/case_records.json
AI_RISK_ORDER_PROFILE_PATH=data/risk/order_profiles.json
AI_RISK_STRATEGY_PROFILE_PATH=data/risk/strategy_profiles.json
AI_RISK_STRATEGY_SIMULATION_PATH=data/risk/strategy_simulations.json
AI_RISK_GRAPH_RELATION_PATH=data/risk/graph_relations.json

# External HTTP risk service
AI_RISK_TOOL_HTTP_BASE_URL=http://127.0.0.1:8090
AI_RISK_TOOL_HTTP_TIMEOUT_SEC=5
AI_RISK_TOOL_HTTP_RETRY_ATTEMPTS=2
AI_RISK_TOOL_HTTP_RETRY_BACKOFF_SEC=0.1
AI_RISK_TOOL_HTTP_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_RISK_TOOL_HTTP_CIRCUIT_BREAKER_RESET_SEC=30
# Append-only, redacted audit trail for every external HTTP attempt.
AI_RISK_TOOL_HTTP_AUDIT_ENABLED=true
AI_RISK_TOOL_HTTP_AUDIT_PATH=.data/upstream-audit.jsonl
AI_RISK_TOOL_HTTP_AUDIT_MAX_BYTES=10485760
AI_RISK_TOOL_HTTP_AUDIT_MAX_FILES=5

# HTTP endpoint mapping
AI_RISK_TOOL_HTTP_METRIC_PATH=/metric-snapshots
AI_RISK_TOOL_HTTP_CASE_PATH=/case-records
AI_RISK_TOOL_HTTP_ORDER_PATH_TEMPLATE=/order-profiles/{order_id}
AI_RISK_TOOL_HTTP_STRATEGY_PROFILE_PATH_TEMPLATE=/strategy-profiles/{strategy_id}
AI_RISK_TOOL_HTTP_STRATEGY_SIMULATION_PATH_TEMPLATE=/strategy-simulations/{strategy_id}
AI_RISK_TOOL_HTTP_GRAPH_RELATION_PATH_TEMPLATE=/graph-relations/{entity_id}
AI_RISK_TOOL_HTTP_COUNTRY_PARAM=country
AI_RISK_TOOL_HTTP_CHANNEL_PARAM=channel

# Authentication
# Supported values: none / bearer / api_key
AI_RISK_TOOL_HTTP_AUTH_MODE=none
AI_RISK_TOOL_HTTP_AUTH_HEADER=Authorization
# Prefer *_TOKEN_FILE for real deployments. Raw token env is for local use only.
AI_RISK_TOOL_HTTP_AUTH_TOKEN=
AI_RISK_TOOL_HTTP_AUTH_TOKEN_FILE=

# Admin endpoint protection for /admin/* and /metrics.
AI_RISK_ADMIN_AUTH_ENABLED=false
AI_RISK_ADMIN_AUTH_HEADER=X-Admin-Token
AI_RISK_ADMIN_AUTH_TOKEN=
AI_RISK_ADMIN_AUTH_TOKEN_FILE=
