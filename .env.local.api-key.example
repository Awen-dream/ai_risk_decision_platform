# Core runtime mode
AI_RISK_KNOWLEDGE_BACKEND=file
AI_RISK_TOOL_BACKEND=http

# Agent API
AI_RISK_API_HOST=127.0.0.1
AI_RISK_API_PORT=8000

# Knowledge source
AI_RISK_KNOWLEDGE_DIR=data/knowledge

# External HTTP risk service
AI_RISK_TOOL_HTTP_BASE_URL=https://risk-api.example.com
AI_RISK_TOOL_HTTP_TIMEOUT_SEC=5

# HTTP endpoint mapping
AI_RISK_TOOL_HTTP_METRIC_PATH=/v1/risk/metric-snapshots
AI_RISK_TOOL_HTTP_CASE_PATH=/v1/risk/case-records
AI_RISK_TOOL_HTTP_ORDER_PATH_TEMPLATE=/v1/risk/order-profiles/{order_id}
AI_RISK_TOOL_HTTP_STRATEGY_PROFILE_PATH_TEMPLATE=/v1/risk/strategies/{strategy_id}
AI_RISK_TOOL_HTTP_STRATEGY_SIMULATION_PATH_TEMPLATE=/v1/risk/strategies/{strategy_id}/simulation
AI_RISK_TOOL_HTTP_GRAPH_RELATION_PATH_TEMPLATE=/v1/risk/graph-relations/{entity_id}
AI_RISK_TOOL_HTTP_COUNTRY_PARAM=countryCode
AI_RISK_TOOL_HTTP_CHANNEL_PARAM=paymentChannel

# API key authentication
AI_RISK_TOOL_HTTP_AUTH_MODE=api_key
AI_RISK_TOOL_HTTP_AUTH_HEADER=X-API-Key
AI_RISK_TOOL_HTTP_AUTH_TOKEN=replace-with-real-api-key
