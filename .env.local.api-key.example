# Core runtime mode
AI_RISK_KNOWLEDGE_BACKEND=file
AI_RISK_TOOL_BACKEND=http

# Agent API
AI_RISK_API_HOST=127.0.0.1
AI_RISK_API_PORT=8000

# Knowledge source
AI_RISK_KNOWLEDGE_DIR=data/knowledge

# Runtime persistence
AI_RISK_SESSION_STORE_BACKEND=sqlite
AI_RISK_CASE_STORE_BACKEND=sqlite
AI_RISK_DATABASE_PATH=.data/platform.db
AI_RISK_POSTGRES_DSN_FILE=

# External HTTP risk service
AI_RISK_TOOL_HTTP_BASE_URL=https://risk-api.example.com
AI_RISK_TOOL_HTTP_TIMEOUT_SEC=5
AI_RISK_TOOL_HTTP_RETRY_ATTEMPTS=2
AI_RISK_TOOL_HTTP_RETRY_BACKOFF_SEC=0.1
AI_RISK_TOOL_HTTP_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
AI_RISK_TOOL_HTTP_CIRCUIT_BREAKER_RESET_SEC=30
AI_RISK_TOOL_HTTP_AUDIT_ENABLED=true
AI_RISK_TOOL_HTTP_AUDIT_PATH=.data/upstream-audit.jsonl
AI_RISK_TOOL_HTTP_AUDIT_MAX_BYTES=10485760
AI_RISK_TOOL_HTTP_AUDIT_MAX_FILES=5
AI_RISK_TOOL_HTTP_AUDIT_INTEGRITY_ENABLED=true
AI_RISK_AUDIT_CENTRAL_ENABLED=false
AI_RISK_AUDIT_CENTRAL_URL=
AI_RISK_AUDIT_CENTRAL_TIMEOUT_SEC=3
AI_RISK_AUDIT_CENTRAL_AUTH_HEADER=Authorization
AI_RISK_AUDIT_CENTRAL_AUTH_TOKEN_FILE=

# HTTP endpoint mapping
AI_RISK_TOOL_HTTP_METRIC_PATH=/v1/risk/metric-snapshots
AI_RISK_TOOL_HTTP_CASE_PATH=/v1/risk/case-records
AI_RISK_TOOL_HTTP_ORDER_PATH_TEMPLATE=/v1/risk/order-profiles/{order_id}
AI_RISK_TOOL_HTTP_STRATEGY_PROFILE_PATH_TEMPLATE=/v1/risk/strategies/{strategy_id}
AI_RISK_TOOL_HTTP_STRATEGY_SIMULATION_PATH_TEMPLATE=/v1/risk/strategies/{strategy_id}/simulation
AI_RISK_TOOL_HTTP_GRAPH_RELATION_PATH_TEMPLATE=/v1/risk/graph-relations/{entity_id}
AI_RISK_TOOL_HTTP_COUNTRY_PARAM=countryCode
AI_RISK_TOOL_HTTP_CHANNEL_PARAM=paymentChannel

# API key authentication
AI_RISK_TOOL_HTTP_AUTH_MODE=api_key
AI_RISK_TOOL_HTTP_AUTH_HEADER=X-API-Key
AI_RISK_TOOL_HTTP_AUTH_TOKEN=
AI_RISK_TOOL_HTTP_AUTH_TOKEN_FILE=/run/secrets/risk-api-key

# Protect /admin/* and /metrics in shared environments.
AI_RISK_ADMIN_AUTH_ENABLED=true
AI_RISK_ADMIN_AUTH_HEADER=X-Admin-Token
AI_RISK_ADMIN_AUTH_TOKEN=
AI_RISK_ADMIN_AUTH_TOKEN_FILE=/run/secrets/ai-risk-admin-token
